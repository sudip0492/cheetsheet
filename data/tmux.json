{
  "Session Management": [
    { "cmd": "tmux", "desc": "Start a new tmux session" },
    { "cmd": "tmux new -s <name>", "desc": "Create a named session" },
    { "cmd": "tmux new -s <name> -d", "desc": "Create a detached session" },
    { "cmd": "tmux ls", "desc": "List all sessions" },
    { "cmd": "tmux attach", "desc": "Attach to the last session" },
    { "cmd": "tmux a", "desc": "Attach to the last session (shorthand)" },
    { "cmd": "tmux attach -t <name>", "desc": "Attach to a named session" },
    { "cmd": "tmux kill-session -t <name>", "desc": "Kill a session" },
    { "cmd": "tmux kill-server", "desc": "Kill the tmux server" },
    { "cmd": "tmux rename-session -t <old> <new>", "desc": "Rename a session" },
    { "cmd": "tmux switch -t <name>", "desc": "Switch to a session" },
    { "cmd": "Ctrl+b d", "desc": "Detach from the current session" }
  ],
  "Windows": [
    { "cmd": "Ctrl+b c", "desc": "Create a new window" },
    { "cmd": "Ctrl+b ,", "desc": "Rename the current window" },
    { "cmd": "Ctrl+b n", "desc": "Switch to the next window" },
    { "cmd": "Ctrl+b p", "desc": "Switch to the previous window" },
    { "cmd": "Ctrl+b l", "desc": "Switch to the last active window" },
    { "cmd": "Ctrl+b &", "desc": "Kill the current window" },
    { "cmd": "Ctrl+b w", "desc": "List all windows" },
    { "cmd": "Ctrl+b f", "desc": "Find a window" },
    { "cmd": "Ctrl+b .", "desc": "Move the current window" },
    { "cmd": "Ctrl+b <0-9>", "desc": "Switch to a window by number" }
  ],
  "Panes": [
    { "cmd": "Ctrl+b %", "desc": "Split pane vertically" },
    { "cmd": "Ctrl+b \"", "desc": "Split pane horizontally" },
    { "cmd": "Ctrl+b x", "desc": "Kill the current pane" },
    { "cmd": "Ctrl+b z", "desc": "Toggle pane zoom" },
    { "cmd": "Ctrl+b o", "desc": "Cycle through panes" },
    { "cmd": "Ctrl+b <arrow>", "desc": "Select pane by direction" },
    { "cmd": "Ctrl+b ;", "desc": "Switch to the last active pane" },
    { "cmd": "Ctrl+b q", "desc": "Show pane numbers" },
    { "cmd": "Ctrl+b {", "desc": "Swap with the previous pane" },
    { "cmd": "Ctrl+b }", "desc": "Swap with the next pane" },
    { "cmd": "Ctrl+b Space", "desc": "Cycle through pane layouts" },
    { "cmd": "Ctrl+b !", "desc": "Break pane into a new window" },
    { "cmd": "Ctrl+b Alt+<arrow>", "desc": "Resize pane by 5 cells" },
    { "cmd": "Ctrl+b m", "desc": "Mark the current pane" },
    { "cmd": "Ctrl+b M", "desc": "Clear the marked pane" }
  ],
  "Copy Mode": [
    { "cmd": "Ctrl+b [", "desc": "Enter copy mode" },
    { "cmd": "Space", "desc": "Start selection" },
    { "cmd": "Enter", "desc": "Copy selection" },
    { "cmd": "Ctrl+b ]", "desc": "Paste from buffer" },
    { "cmd": "/", "desc": "Search forward" },
    { "cmd": "?", "desc": "Search backward" },
    { "cmd": "n", "desc": "Jump to the next match" },
    { "cmd": "N", "desc": "Jump to the previous match" }
  ],
  "Configuration": [
    { "cmd": "Ctrl+b :", "desc": "Enter command mode" },
    { "cmd": "Ctrl+b ?", "desc": "Show key bindings" },
    { "cmd": "tmux list-keys", "desc": "List all key bindings" },
    { "cmd": "set -g mouse on", "desc": "Enable mouse mode" },
    { "cmd": "tmux source ~/.tmux.conf", "desc": "Reload configuration" },
    { "cmd": "Ctrl+b ~", "desc": "Show previous messages" }
  ]
}